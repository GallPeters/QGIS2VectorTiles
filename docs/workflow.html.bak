<button class="back-top" id="backTop" aria-label="Back to top" title="Back to top">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
</button>

<script>
const workflowData = {
  orchestrator: {
    title: "QGIS2VectorTiles.py",
    desc: "The core plugin framework entry point script. It manages operational properties, runtime variables, and coordinates the sequential execution of all nested scripts across the workspace environment.",
    deps: [],
    file: "QGIS2VectorTiles.py"
  },
  node1: {
    title: "rule_flattener.py",
    desc: "Processes intricate desktop renderer rules and layered map labeling states down to clear, non-nested conditional groups. It flattens compound parameters into uniform structures, preserving filters and scaling logic.",
    deps: [],
    file: "rule_flattener.py"
  },
  node2: {
    title: "rule_exporter.py",
    desc: "Slices vector features matching specific style rules into separate intermediate datastores. It executes spatial bounds trimming, geometry correction, and functional database schemas prior to downstream generation.",
    deps: ["ddp_fetcher.py"],
    file: "rule_exporter.py"
  },
  "ddp_fetcher.py": {
    title: "ddp_fetcher.py",
    desc: "Helper asset used inside the rule export framework to extract, parse, and evaluate localized data-defined properties attached to active geometry styles.",
    deps: [],
    file: "ddp_fetcher.py"
  },
  node3: {
    title: "tiles_generator.py",
    desc: "Coordinates multi-threaded tile slicing processes over the intermediate geometries. It hooks directly into system-level GDAL installations, running optimized map routines bounded by client multi-core configurations.",
    deps: [],
    file: "tiles_generator.py"
  },
  node4: {
    title: "tiles_styler.py",
    desc: "Transforms styling definitions originating from desktop properties, matching them to newly minted vector channels. It outputs unified QGIS vector tile specification archives (.qlr layers).",
    deps: [],
    file: "tiles_styler.py"
  },
  node5: {
    title: "maplibre_converter.py",
    desc: "Translates active QGIS configurations into client-side MapLibre JSON schemas. It maps coordinate grids, fonts, zoom limits, and design specifications into web formats.",
    deps: ["sprite_generator.py", "glyphs_generator.py (Planned)"],
    file: "maplibre_converter.py"
  },
  "sprite_generator.py": {
    title: "sprite_generator.py",
    desc: "Utility module that packages map markers, point symbols, and vector designs into consolidated layout sprite graphics paired with look-up coordinates.",
    deps: [],
    file: "sprite_generator.py"
  },
  "glyphs_generator.py": {
    title: "glyphs_generator.py",
    desc: "Planned architectural asset intended to break operational system typography and label packages down into web font protobuffer channels (.pbf structure).",
    deps: [],
    file: "glyphs_generator.py"
  },
  node6: {
    title: "server_initializer.py",
    desc: "Bundles output formats, scripts, map styles, and local resources inside destination directories. It provides instant web preview frameworks via background Python distribution tools.",
    deps: [],
    file: "server_initializer.py"
  }
};

(function () {
  // Target Base Path for Core Core Source Files
  const gitHubBasePath = "https://github.com/GallPeters/QGIS2VectorTiles/blob/main/src/core/";

  // Modal Structure Hooks
  const modal = document.getElementById('wfModal');
  const modalTitle = document.getElementById('modalTitle');
  const modalDesc = document.getElementById('modalDesc');
  const modalDepsSection = document.getElementById('modalDepsSection');
  const modalDeps = document.getElementById('modalDeps');
  const modalGitLink = document.getElementById('modalGitLink');
  const modalClose = document.getElementById('modalClose');

  function openModal(key) {
    const data = workflowData[key];
    if (!data) return;

    modalTitle.textContent = data.title;
    modalDesc.textContent = data.desc;
    
    // Normalize string parameters to map directly into target github structure
    const sanitizedFileName = data.file.replace(' (Planned)', '');
    modalGitLink.href = `${gitHubBasePath}${sanitizedFileName}`;

    modalDeps.innerHTML = '';
    if (data.deps && data.deps.length > 0) {
      modalDepsSection.style.display = 'block';
      data.deps.forEach(dep => {
        const span = document.createElement('span');
        span.className = 'dep-tag';
        if (dep.includes('(Planned)')) {
          span.classList.add('planned');
        }
        span.textContent = dep;
        modalDeps.appendChild(span);
      });
    } else {
      modalDepsSection.style.display = 'none';
    }

    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Intercept triggers on elements containing data-nodes (both steps and branches)
  document.querySelectorAll('[data-node]').forEach(elem => {
    elem.addEventListener('click', function(e) {
      e.stopPropagation();
      openModal(this.getAttribute('data-node'));
    });
  });

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e) {
    if (e.target === modal) closeModal();
  });

  window.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });

  // Back to Top Functionality
  var btn = document.getElementById('backTop');
  if (!btn) return;

  var threshold = 480;
  var ticking = false;

  function update() {
    if (window.scrollY > threshold) btn.classList.add('visible');
    else btn.classList.remove('visible');
    ticking = false;
  }

  window.addEventListener('scroll', function () {
    if (!ticking) {
      window.requestAnimationFrame(update);
      ticking = true;
    }
  }, { passive: true });

  btn.addEventListener('click', function () {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
</script>

</body>
</html>