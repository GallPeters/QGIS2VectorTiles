<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/png" sizes="16x16" href="icons/qgis2vectortiles.png">
<link rel="shortcut icon" href="docs/icons/qgis2vectortiles.ico">
<title>QGIS2VectorTiles — Workflow</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

/* DESIGN TOKENS
   Flat dark UI — QGIS brand palette. */
:root {
  /* Surfaces (opaque) */
  --bg:            #0d0d0d;
  --surface:       #161616;
  --surface-2:     #1c1c1c;
  --surface-3:     #222222;

  /* Borders (solid) */
  --border:        #262626;
  --border-2:      #333333;
  --border-3:      #404040;

  /* Brand accents — QGIS */
  --accent:        #98B023;
  --accent-hover:  #A9C33A;
  --accent-deep:   #38410F;
  --accent-2:      #98B023;

  /* Typography */
  --text:          #ececec;
  --text-muted:    #a0a0a0;
  --text-dim:      #6f6f6f;
  --text-faint:    #4a4a4a;

  --header-h:      56px;

  /* Border radii */
  --r-sm: 3px;
  --r-md: 4px;
  --r-lg: 6px;

  --t:      0.15s ease;
  --t-slow: 0.25s ease;

  --max-w: 1180px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-behavior: smooth;
  scroll-padding-top: var(--header-h);
  background: var(--bg);
}

body {
  font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.55;
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }
img, video, svg { display: block; max-width: 100%; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }
::selection { background: var(--accent); color: var(--bg); }

/* FIXED HEADER */
.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  height: var(--header-h);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}

.header-inner {
  height: 100%;
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.nav-left, .nav-right {
  display: flex;
  align-items: center;
}
.nav-left  { gap: 4px; }
.nav-right { gap: 14px; }

.nav-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  padding: 7px 12px;
  border-radius: var(--r-sm);
  transition: color var(--t), background var(--t), border-color var(--t);
  letter-spacing: -0.005em;
  border: 1px solid transparent;
}
.nav-btn svg { opacity: 0.9; flex-shrink: 0; }
.nav-btn:hover { color: var(--text); background: var(--surface-2); }

.nav-btn.cta {
  color: #0d0d0d;
  background: var(--accent);
  border-color: var(--accent);
  font-weight: 600;
}
.nav-btn.cta:hover {
  background: var(--accent-hover);
  border-color: var(--accent-hover);
  color: #0d0d0d;
}
.nav-btn.cta svg { opacity: 1; color: #0d0d0d; }

.nav-btn.active {
  color: var(--text);
  background: var(--surface-2);
  border-color: var(--border-2);
}
.nav-btn.active svg { opacity: 1; color: var(--accent); }

.nav-btn.home { color: var(--text-muted); }
.nav-btn.home:hover { color: var(--accent); border-color: var(--border-2); background: var(--surface-2); }
.nav-btn.home:hover svg { color: var(--accent); }

.rate-text {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12.5px;
  color: var(--text-dim);
  font-weight: 400;
  white-space: nowrap;
}
.rate-text strong { color: var(--accent-2); font-weight: 600; }

.header-links {
  display: flex;
  align-items: center;
  gap: 2px;
}

.icon-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  color: var(--text-muted);
  border-radius: var(--r-sm);
  transition: color var(--t), background var(--t);
}
.icon-link:hover { color: var(--accent); background: var(--surface-2); }
.icon-link svg { width: 15px; height: 15px; }

.divider-v {
  width: 1px;
  height: 18px;
  background: var(--border-2);
  flex-shrink: 0;
}

/* PAGE HEADER */
.page-head {
  position: relative;
  text-align: center;
  padding: calc(var(--header-h) + 64px) 28px 56px;
  border-bottom: 1px solid var(--border);
  background: var(--bg);
  overflow: hidden;
}

.page-head-content {
  position: relative;
  max-width: 720px;
  margin: 0 auto;
}

.page-icon {
  width: 64px;
  height: 64px;
  margin: 0 auto 22px;
  overflow: hidden;
  border: 0px solid var(--border-2);
  background: #000;
}
.page-icon img { width: 100%; height: 100%; display: block; }

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 18px;
}
.eyebrow::before {
  content: '';
  width: 14px;
  height: 2px;
  background: var(--accent);
  display: inline-block;
}

.page-head h1 {
  font-size: clamp(34px, 5vw, 50px);
  font-weight: 600;
  letter-spacing: -0.028em;
  line-height: 1.08;
  color: var(--text);
}
.page-head h1 .accent { color: var(--accent); }

.page-tagline {
  margin-top: 16px;
  font-size: clamp(15px, 1.2vw, 16.5px);
  color: var(--text-muted);
  line-height: 1.6;
  max-width: 540px;
  margin-left: auto;
  margin-right: auto;
}

/* WIDE PAGE CONTENT EXTENT */
.page-content {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 56px 24px 96px;
}

/* MAIN ORCHESTRATOR WRAPPER CONTAINER */
.orchestrator-container {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--accent);
  border-radius: var(--r-lg);
  padding: 36px 24px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  position: relative;
  cursor: pointer;
  transition: background var(--t), box-shadow var(--t), border-color var(--t);
}

.orchestrator-container:hover {
  background: #191919;
  border-color: var(--accent-hover);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);
}

.orchestrator-meta {
  max-width: 580px;
  margin: 0 auto 36px;
  text-align: center;
  border-bottom: 1px solid var(--border-2);
  padding-bottom: 24px;
}

.orchestrator-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #0d0d0d;
  background: var(--accent);
  padding: 3px 10px;
  border-radius: var(--r-sm);
  display: inline-block;
  margin-bottom: 8px;
}

.orchestrator-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 6px;
  letter-spacing: -0.015em;
}

.orchestrator-desc {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1.5;
}

/* PIPELINE SYSTEM */
.wf-pipeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* 3-Column Node Row Architecture */
.wf-node-row {
  display: grid;
  grid-template-columns: 1fr 580px 1fr;
  align-items: center;
  width: 100%;
}

/* Connectors That Seamlessly Touch Adjacent Containers */
.wf-connector {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 42px;
  width: 580px;
  position: relative;
}

.wf-connector .line {
  width: 2px;
  height: 100%;
  background: var(--border-3);
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
}

.wf-connector .arrow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18px;
  height: 18px;
  color: var(--accent);
  background: var(--surface);
  padding: 2px;
  z-index: 2;
  transition: color var(--t);
}
.orchestrator-container:hover .wf-connector .arrow {
  background: #191919;
}

/* Center Pipeline Nodes */
.wf-node {
  background: var(--surface-2);
  border: 1px solid var(--border-2);
  border-radius: var(--r-md);
  padding: 18px 20px;
  transition: border-color var(--t), background var(--t), transform var(--t), box-shadow var(--t);
  display: flex;
  gap: 16px;
  align-items: flex-start;
  position: relative;
  z-index: 3;
}

.wf-node:hover {
  border-color: var(--border-3);
  background: var(--surface-3);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
}

.wf-node-step {
  font-family: ui-monospace, "SF Mono", "JetBrains Mono", monospace;
  font-size: 12px;
  color: var(--accent);
  font-weight: 600;
  background: var(--surface-3);
  border: 1px solid var(--border-2);
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.wf-node:hover .wf-node-step {
  background: var(--accent-deep);
  border-color: var(--accent);
}

.wf-node-icon {
  color: var(--text-dim);
  flex-shrink: 0;
  margin-top: 3px;
  transition: color var(--t);
}
.wf-node:hover .wf-node-icon {
  color: var(--accent);
}

.wf-node-content {
  flex: 1;
  min-width: 0;
}

.wf-node-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}

.wf-node-desc {
  font-size: 13.5px;
  color: var(--text-muted);
  line-height: 1.5;
}

/* Side Branch Elements for Script Dependencies */
.wf-branches-left, .wf-branches-right {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.wf-branches-right {
  padding-left: 24px;
}

.wf-branch-item {
  display: flex;
  align-items: center;
  position: relative;
}

.wf-branches-right .wf-branch-item::before {
  content: '';
  position: absolute;
  left: -24px;
  top: 50%;
  width: 24px;
  height: 2px;
  background: var(--border-3);
  z-index: 1;
}

.branch-node {
  font-family: ui-monospace, "SF Mono", "JetBrains Mono", monospace;
  font-size: 12px;
  background: var(--surface-2);
  border: 1px solid var(--border-2);
  padding: 6px 12px;
  border-radius: var(--r-sm);
  color: var(--text-muted);
  transition: border-color var(--t), color var(--t), background var(--t);
  cursor: pointer;
  white-space: nowrap;
  z-index: 2;
}

.branch-node:hover {
  border-color: var(--accent);
  color: var(--text);
  background: var(--surface-3);
}

.branch-node.planned {
  border-style: dashed;
  color: var(--text-dim);
}

/* MODAL DIALOG POPUPS */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(5, 5, 5, 0.85);
  backdrop-filter: blur(4px);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--t-slow);
}

.modal-overlay.open {
  opacity: 1;
  pointer-events: auto;
}

.modal-window {
  background: var(--surface-2);
  border: 1px solid var(--border-3);
  border-radius: var(--r-lg);
  width: 100%;
  max-width: 580px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.6);
  transform: translateY(15px);
  transition: transform var(--t-slow);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-overlay.open .modal-window {
  transform: translateY(0);
}

.modal-header {
  padding: 20px 24px;
  border-bottom: 1px solid var(--border-2);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  background: var(--surface);
}

.modal-title-group h2 {
  font-size: 20px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.015em;
}

.modal-close {
  color: var(--text-dim);
  border-radius: var(--r-sm);
  padding: 4px;
  transition: color var(--t), background var(--t);
  display: inline-flex;
}
.modal-close:hover {
  color: var(--text);
  background: var(--surface-3);
}

.modal-body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  overflow-y: auto;
  max-height: calc(80vh - 120px);
}

.modal-section-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 8px;
}

.modal-text {
  font-size: 14.5px;
  color: var(--text-muted);
  line-height: 1.6;
}

.dep-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.dep-tag {
  font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
  font-size: 12px;
  color: var(--text);
  background: var(--surface-3);
  border: 1px solid var(--border-2);
  padding: 4px 10px;
  border-radius: var(--r-sm);
}
.dep-tag.planned {
  border-style: dashed;
  color: var(--text-dim);
}

.modal-footer {
  padding: 16px 24px;
  border-top: 1px solid var(--border-2);
  background: var(--surface);
  display: flex;
  justify-content: flex-end;
}

.btn-github {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
  color: #0d0d0d;
  background: var(--accent);
  border: 1px solid var(--accent);
  padding: 8px 16px;
  border-radius: var(--r-sm);
  transition: background var(--t), border-color var(--t);
}
.btn-github:hover {
  background: var(--accent-hover);
  border-color: var(--accent-hover);
}

/* PAGE FOOTER */
.page-foot {
  margin-top: 64px;
  padding-top: 24px;
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  font-size: 12px;
  color: var(--text-dim);
  flex-wrap: wrap;
}
.page-foot a { color: var(--text-muted); transition: color var(--t); }
.page-foot a:hover { color: var(--accent); }

/* BACK TO TOP */
.back-top {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 40px;
  height: 40px;
  border-radius: var(--r-md);
  background: var(--surface-2);
  border: 1px solid var(--border-2);
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transform: translateY(8px);
  transition: opacity var(--t-slow), transform var(--t-slow), background var(--t), border-color var(--t), color var(--t);
  z-index: 90;
}
.back-top.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
.back-top:hover {
  background: var(--surface-3);
  border-color: var(--accent);
  color: var(--accent);
}
.back-top svg { width: 14px; height: 14px; }

/* RESPONSIVE BREAKPOINTS */
@media (max-width: 1024px) {
  .wf-node-row {
    grid-template-columns: 1fr;
    justify-items: center;
    gap: 12px;
  }
  .wf-connector {
    width: 100%;
  }
  .wf-branches-right {
    padding-left: 0;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
  }
  .wf-branches-right .wf-branch-item::before {
    display: none;
  }
}

@media (max-width: 768px) {
  :root { --header-h: 52px; }

  .header-inner { padding: 0 14px; gap: 8px; }
  .nav-btn { padding: 7px 10px; font-size: 12.5px; }
  .nav-btn .label { display: none; }
  .nav-btn.cta .label { display: inline; }
  .rate-text { display: none; }
  .divider-v { display: none; }
  .nav-right { gap: 4px; }

  .page-head { padding: calc(var(--header-h) + 44px) 18px 40px; }
  .page-icon { width: 48px; height: 48px; margin-bottom: 18px; }

  .page-content { padding: 40px 14px 72px; }
  .orchestrator-container { padding: 24px 14px; }

  .page-foot { font-size: 11.5px; gap: 10px; flex-direction: column; text-align: center; }
  .back-top { bottom: 16px; right: 16px; width: 36px; height: 36px; }
}

@media (max-width: 420px) {
  .nav-btn { padding: 6px 8px; gap: 0; }
  .header-inner { gap: 4px; }
}
</style>
</head>
<body>

<header class="header">
  <div class="header-inner">

    <nav class="nav-left">
      <a href="index.html" class="nav-btn home" aria-label="Back to home">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        <span class="label">Home</span>
      </a>
      <a href="https://plugins.qgis.org/plugins/QGIS2VectorTiles" target="_blank" class="nav-btn cta">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span class="label">Download</span>
      </a>
      <a href="demos.html" class="nav-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        <span class="label">Demos</span>
      </a>
      <a href="workflow.html" class="nav-btn active" aria-current="page">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        <span class="label">Workflow</span>
      </a>
      <a href="changelog.html" class="nav-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="label">Changelog</span>
      </a>
      <a href="compatibility.html" class="nav-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
        <span class="label">Styling Guide</span>
      </a>
    </nav>

    <div class="nav-right">
      <span class="rate-text">Enjoying the plugin? <strong>Rate it</strong></span>
      <span class="divider-v"></span>
      <div class="header-links">
        <a href="https://plugins.qgis.org/plugins/QGIS2VectorTiles" target="_blank" class="icon-link" aria-label="QGIS Plugin Repository" title="QGIS Plugin Repository">
          <svg viewBox="0 0 32 32" fill="currentColor"><path d="M12.879 13.006v3.65l-3.004-3.048v-3.495h3.582l2.852 2.893h-3.43zm10.886 7.606V24h-3.654l-5.73-5.9v-3.55h3.354l6.03 6.062zm-10.828-1.448l3.372 3.371c-1.309.442-2.557.726-4.325.726C5.136 23.26 0 18.243 0 11.565 0 4.92 5.136 0 11.984 0 18.864 0 24 4.952 24 11.565c0 2.12-.523 4.076-1.457 5.759l-3.625-3.725a8.393 8.393 0 0 0 .24-2.005c0-4.291-3.148-7.527-7.1-7.527-3.954 0-7.248 3.236-7.248 7.527s3.33 7.6 7.247 7.6c.548 0 .661.017.88-.03z"/></svg>
        </a>
        <a href="https://github.com/GallPeters/QGIS2VectorTiles" target="_blank" class="icon-link" aria-label="GitHub" title="GitHub">
